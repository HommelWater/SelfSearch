{
  "manifest_version": 3,
  "name": "Personal Search Engine",
  "version": "1.0",
  "description": "Collects site data for your personal search engine.",
  "content_scripts": [
      {
          "matches": ["<all_urls>"],
          "js": ["content.js"],
          "run_at": "document_end"
      }
  ],
  "permissions": [
      "tabs",
      "storage"
  ],
  "host_permissions": [
      "<all_urls>"
  ]
}