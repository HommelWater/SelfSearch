{
  "manifest_version": 3,
  "name": "Personal Search Engine",
  "version": "1.0",
  "description": "Collects site data for your personal search engine.",
  "content_scripts": [
      {
          "matches": ["<all_urls>"],
          "js": ["content.js"],
          "run_at": "document_end"
      }
  ],
  "permissions": [
      "tabs", "activeTab"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "host_permissions": [
    "http://127.0.0.1:5000/"
  ]
}
