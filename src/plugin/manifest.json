{
  "manifest_version": 2,
  "name": "Bombus Search",
  "version": "1.1.0",
  "description": "Index webpages to your Bombus server.",
  "permissions": ["activeTab", "storage", "tabs", "<all_urls>"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Index this page"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hommelwater@gmail.com"
    }
  }
}